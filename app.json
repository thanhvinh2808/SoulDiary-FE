{
  "expo": {
    "name": "SoulDiary",
    "slug": "SoulDiary",
    "scheme": "souldiary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/soul_diary_icon_1024.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/soul_diary_splash_512.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vinh.souldiary",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "souldiary",
              "fb913094248341605"
            ]
          }
        ],
        "LSApplicationQueriesSchemes": [
          "fbapi",
          "fb-messenger-share-api"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/soul_diary_icon_adaptive_1024.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.vinh.souldiary",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "souldiary"
            },
            {
              "scheme": "fb913094248341605"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#FDFBF7"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "44707e7b-7aa0-4788-b759-8d90dd5d37f9"
      }
    }
  }
}
